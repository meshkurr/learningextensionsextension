{
  "name": "learningextensionsextension",
  "displayName": "LearningExtensionsExtension",
  "description": "This is an extension to learn extensions",
  "version": "0.0.1",
  "publisher": "meshach-erisca",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "learningextensionsextension.goodbyeworld",
        "title": "Goodbye World"
      },
      {
        "command": "learningextensionsextension.helloworld",
        "title": "Hello World"
      },
      {
        "command": "learningextensionsextension.testerror",
        "title": "Test Error Message"
      },
      {
        "command": "learningextensionsextension.testopendialog",
        "title": "Test Open Dialog"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fileShareContainer",
          "title": "Select Files to Share",
          "icon": "media/ShareIcon.png"
        }
      ]
    },
    "views": {
      "fileShareContainer": [
        {
          "id": "fileShareSelector",
          "name": "",
          "icon": "media/ShareIcon.png"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.54.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}